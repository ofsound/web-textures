DATABASE_URL=postgres://user:password@host:5432/dbname
NUXT_AUTH_SECRET=change-me
NUXT_ADMIN_EMAILS=admin@example.com
NUXT_ADMIN_PASSWORD=change-me
# Public browser origin only (no path). Used to build auth base URL when NUXT_AUTH_ORIGIN is unset.
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Full auth base URL (Sidebase / Auth.js). On a custom domain (e.g. svg.ofsound.net), set this to that origin + /api/auth in Cloudflare.
NUXT_AUTH_ORIGIN=http://localhost:3000/api/auth
DATABASE_URL=postgres://user:password@host:5432/dbname
# Optional duplicate for Nuxt runtime (set on Cloudflare if DATABASE_URL alone is not visible to the Worker).
# NUXT_DATABASE_URL=postgres://user:password@host:5432/dbname
NUXT_AUTH_SECRET=change-me
NUXT_ADMIN_EMAILS=admin@example.com
NUXT_ADMIN_PASSWORD=change-me
# Public browser origin only (no path). Used to build auth base URL when NUXT_AUTH_ORIGIN is unset.
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Auth base URL for Sidebase (must end with /api/auth). If you set only the site origin, /api/auth is appended automatically.
NUXT_AUTH_ORIGIN=http://localhost:3000/api/auth
#
# Cloudflare Pages: set NUXT_AUTH_ORIGIN to your live site + /api/auth (e.g. https://svg.ofsound.net/api/auth).
# If deploy still reports AUTH_NO_ORIGIN, add the same variable under Build configuration so it exists
# during `nuxt build` / wrangler upload, or rely on CF_PAGES_URL + NUXT_PUBLIC_SITE_URL (see nuxt.config).
#
# Admin login on production: set NUXT_AUTH_SECRET, NUXT_ADMIN_EMAILS, and NUXT_ADMIN_PASSWORD in the
# Pages/Workers environment (Production). Missing or mismatched values cause 401 on sign-in.